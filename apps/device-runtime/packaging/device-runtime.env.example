# Copy to /etc/rnfleet/device-runtime.env and customize per appliance/site.
CONTROL_PLANE_URL=https://rn-fleet-manager-control-plane.vercel.app
FLEET_PSK=dev-fleet-psk
# IPSec pre-shared key for the GSA device link. Falls back to FLEET_PSK if unset.
TUNNEL_PSK=dev-fleet-psk
DEVICE_ID=device-001
SITE_ID=lab-site
LOOP_SECONDS=10
# Optional: route-based XFRM interface id used to isolate GSA tunnel traffic
# (defaults to 42). Must be unique per tunnel if multiple are ever configured.
# TUNNEL_IF_ID=42
# Optional: set TUNNEL_DRY_RUN=true to render swanctl/FRR config and log it
# WITHOUT touching the live tunnel — useful for pre-deploy validation.
# TUNNEL_DRY_RUN=false
